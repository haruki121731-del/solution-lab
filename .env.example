# Solution Lab Environment Configuration

# Application
APP_NAME="Solution Lab"
DEBUG=false
LOG_LEVEL=INFO

# API Server
HOST=0.0.0.0
PORT=8000

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_API_KEY=sk-your-api-key-here
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4000

# Firecrawl (for external research)
FIRECRAWL_API_KEY=fc-your-api-key-here
FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# Session Storage
SESSION_STORAGE_PATH=./sessions
MAX_SESSIONS=100
SESSION_TTL_HOURS=24

# Orchestrator Defaults
DEFAULT_MAX_CYCLES=5
DEFAULT_ALLOW_RESEARCH=true
